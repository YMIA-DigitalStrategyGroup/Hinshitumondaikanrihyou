    "CreateViewSql": "select\r\n     h.[ID] AS HistoryID          \r\n    , h.[RecordId]\r\n    , h.[Who]\r\n    , h.[When]                   \r\n    , h.[ActionName]\r\n    , h.[Comments]               \r\n    , h.[FGC_State] AS WorkflowState\r\n    \r\n    , f.[承認番号] \r\n    , f. [承認日] \r\n    , f. [タイトル] \r\n    , f. [申請内容] \r\n    , f. [対象年月] \r\n    , f. [工事番号] \r\n    , f. [FGC_AssignTo] \r\n    , f. [FGC_State] \r\n    , f. [FGC_CreateDate] \r\n    , f. [FGC_LastModifier] \r\n    , f. [FGC_LastModifyDate] \r\n    , f. [FGC_Creator] \r\n    , f. [FGC_UpdateHelp] \r\n    , f. [FGC_Rowversion] \r\nfrom\r\n    品質問題_Fコスト承認情報_FGC_WHT h\r\ninner join\r\n    品質問題_Fコスト承認情報 f on h.RecordId = CAST(f.[承認番号] AS NVARCHAR(50))",
